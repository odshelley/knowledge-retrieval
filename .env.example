MINIO_SECRET_KEY=minioadmin

# Postgres — match the docker-compose service (used by Dagster)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dagster
POSTGRES_PASSWORD=dagster
POSTGRES_DB=dagster

# Vault path on this machine — read-only input
