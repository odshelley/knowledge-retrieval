# Source folder the daily schedule scans for new paper PDFs (host path; in Docker, the
# mounted path inside the container — see docker-compose volume mount).
SOURCE_DIR=/path/to/papers

# New Neo4j Aura DB (created in Task 4)
NEO4J_NEW_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_NEW_USERNAME=neo4j
NEO4J_NEW_PASSWORD=
NEO4J_NEW_DATABASE=neo4j

# Legacy/portmanteau Aura DB — NOT used by this builder pipeline. Retained only for the
# legacy_neo4j_from_env helper / external scripts; safe to leave blank if you don't use it.
NEO4J_LEGACY_URI=neo4j+s://yyyyyyyy.databases.neo4j.io
NEO4J_LEGACY_USERNAME=neo4j
NEO4J_LEGACY_PASSWORD=
NEO4J_LEGACY_DATABASE=neo4j

# OpenAI (extraction LLM + embeddings)
OPENAI_API_KEY=

# Anthropic (paper summary LLM)
ANTHROPIC_API_KEY=

# MinIO — match the docker-compose service
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Postgres — match the docker-compose service (used by Dagster)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dagster
POSTGRES_PASSWORD=dagster
POSTGRES_DB=dagster

# Postgres pgvector — used by resolved_entities asset for entity resolution decisions
RESOLVER_POSTGRES_DSN=postgresql://user:pass@host:5432/db

# Dagster
DAGSTER_HOME=/Users/osianshelley/Projects/knowledge-retrieval/.dagster_home
